{
  "name": "remark-callout-plus",
  "version": "3.2.1",
  "description": "Remark plugin for GitHub/Obsidian-style callouts, literary types (epigraph/pullquote/aside/sidebar), and accordions with native exclusive expansion. Transforms [!TYPE] blockquotes into styled HTML containers with SVG icons, oklch colors, rich titles, collapsible support, and a Sätteri adapter for Astro 7.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js"
    },
    "./satteri": {
      "types": "./dist/satteri.d.ts",
      "import": "./dist/satteri.js"
    },
    "./styles/callout.css": "./styles/callout.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node tests/test-7-features.mjs && node tests/test-new-features.mjs && node tests/test-expanded-edge-cases.mjs && node tests/test-satteri-adapter.mjs",
    "test:unified": "node tests/test-7-features.mjs && node tests/test-new-features.mjs && node tests/test-expanded-edge-cases.mjs",
    "test:satteri": "node tests/test-satteri-adapter.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "remark",
    "remark-plugin",
    "unified",
    "callout",
    "admonition",
    "blockquote",
    "obsidian",
    "github",
    "mdx",
    "markdown",
    "ast",
    "accordion",
    "epigraph",
    "pullquote",
    "aside",
    "sidebar",
    "satteri",
    "astro"
  ],
  "author": "dr-ishaan",
  "license": "MIT",
  "peerDependencies": {
    "mdast-util-to-hast": "^13.0.0",
    "unified": "^11.0.0",
    "satteri": "^0.9.0"
  },
  "peerDependenciesMeta": {
    "mdast-util-to-hast": { "optional": true },
    "unified": { "optional": true },
    "satteri": { "optional": true }
  },
  "dependencies": {
    "hast-util-from-html": "^2.0.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@types/hast": "^3.0.0",
    "@types/mdast": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/unist": "^3.0.0",
    "mdast-util-to-hast": "^13.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "satteri": "^0.9.3",
    "typescript": "^5.7.0",
    "unified": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dr-ishaan/remark-callout.git"
  },
  "homepage": "https://github.com/dr-ishaan/remark-callout#readme",
  "bugs": {
    "url": "https://github.com/dr-ishaan/remark-callout/issues"
  }
}
